# Observal Server Configuration
# Generated by setup.sh -- edit as needed

# REQUIRED: Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=__SECRET_KEY__

# Database credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=__POSTGRES_PASSWORD__

# ClickHouse credentials
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=__CLICKHOUSE_PASSWORD__

# Internal service URLs (default for Docker Compose networking)
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@observal-db:5432/observal
CLICKHOUSE_URL=clickhouse://${CLICKHOUSE_USER}:${CLICKHOUSE_PASSWORD}@observal-clickhouse:8123/observal
REDIS_URL=redis://observal-redis:6379

# Deployment mode: "local" or "enterprise"

# Frontend URL (used for CORS, SSO callbacks, email links)
# Set to your public domain in production
FRONTEND_URL=__FRONTEND_URL__

# Optional: OAuth / OIDC SSO
# OAUTH_CLIENT_ID=
# OAUTH_CLIENT_SECRET=
# OAUTH_SERVER_METADATA_URL=

# Optional: SAML SSO (enterprise)
# SAML_IDP_ENTITY_ID=
# SAML_IDP_SSO_URL=
# SAML_IDP_X509_CERT=

# Optional: Eval engine (LLM-as-judge)
# EVAL_MODEL_URL=
# EVAL_MODEL_API_KEY=
# EVAL_MODEL_NAME=
# EVAL_MODEL_PROVIDER=

# ClickHouse data retention (days). Set to 0 to disable TTL.
DATA_RETENTION_DAYS=90

# Enterprise license key (leave blank for community edition)
# Get a key: https://observal.dev/enterprise
# OBSERVAL_LICENSE_KEY=
